/* ═══════════════════════════════════════════════════════════════
   SUBIT ENGINE
═══════════════════════════════════════════════════════════════ */
const WHO_BITS  = { ME:"10", WE:"11", YOU:"01", THEY:"00" };
const WHERE_BITS= { EAST:"10", SOUTH:"11", WEST:"01", NORTH:"00" };
const WHEN_BITS = { SPRING:"10", SUMMER:"11", AUTUMN:"01", WINTER:"00" };
const PHASE = { "10":"CITRINITAS","11":"RUBEDO","01":"NIGREDO","00":"ALBEDO" };
const PHASE_COLORS = {
  CITRINITAS:"#c8a830", RUBEDO:"#c03030", NIGREDO:"#7070b0", ALBEDO:"#90a8c0"
};
const PHASE_BG = {
  CITRINITAS:"rgba(200,168,48,.1)", RUBEDO:"rgba(192,48,48,.1)",
  NIGREDO:"rgba(80,80,140,.12)", ALBEDO:"rgba(140,168,192,.08)"
};
const TRIGRAM_COLORS = {
  "000":"#1a3a6e","001":"#1a5c3a","010":"#4a7a1a","011":"#7a6a10",
  "100":"#7a3a10","101":"#7a1a1a","110":"#5a1a3a","111":"#3a1a6e"
};
const WHERE_COLORS = { EAST:"#1a7a9a",SOUTH:"#9a5a1a",WEST:"#5a4a8a",NORTH:"#1a6a4a" };
const WHEN_COLORS  = { SPRING:"#3a9a2a",SUMMER:"#9a8a10",AUTUMN:"#8a5a10",WINTER:"#2a4a8a" };

function subitCode(who, where, when) {
  return WHO_BITS[who] + WHERE_BITS[where] + WHEN_BITS[when];
}
function trigramColor(t3) { return TRIGRAM_COLORS[t3] || "#333"; }
function cardAccent(code6) { return trigramColor(code6.slice(0,3)); }
function phaseOf(who) { return PHASE[WHO_BITS[who]]; }

